/* ============ INSIGHTS SECTION v2 ============ */

/* Scroll-margin so anchor links don't land under the sticky header */
.post-section { scroll-margin-top: 96px; }

/* --------- Table of Contents --------- */
.post-body { display: block; }
.post-body-inner { max-width: 720px; margin: 0 auto; }

@media (min-width: 1080px) {
  .post-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 720px);
    column-gap: 72px;
    justify-content: center;
    align-items: start;
    max-width: 1180px;
    margin: 0 auto;
  }
  .post-toc { position: sticky; top: 96px; align-self: start; max-height: calc(100vh - 120px); overflow-y: auto; padding-right: 8px; margin-bottom: 0; }
  .post-toc summary { list-style: none; cursor: default; pointer-events: none; }
  .post-toc summary::-webkit-details-marker { display: none; }
  .post-toc-summary-arrow { display: none; }
  .post-body-inner { max-width: 720px; margin: 0; }
}

.post-toc {
  font-family: 'Inter Tight', sans-serif;
  margin-bottom: 24px;
}
.post-toc-details { border-top: 1px solid #D4D1CA; border-bottom: 1px solid #D4D1CA; padding: 12px 0; }
@media (min-width: 1080px) { .post-toc-details { border: none; padding: 0; } }
.post-toc summary {
  display: flex; justify-content: space-between; align-items: center;
  cursor: pointer; list-style: none;
  padding: 2px 0;
}
.post-toc summary::-webkit-details-marker { display: none; }
.post-toc-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
  color: #01696F; font-weight: 600;
}
.post-toc-summary-arrow { color: #01696F; font-size: 16px; transition: transform 0.2s ease; display: inline-block; }
.post-toc-details[open] .post-toc-summary-arrow { transform: rotate(90deg); }

.post-toc-list {
  list-style: none; padding: 0; margin: 12px 0 0 0;
}
.post-toc-list li { margin: 0; }
.post-toc-list a {
  display: flex; gap: 10px; align-items: baseline;
  padding: 7px 0;
  color: #4A4844; text-decoration: none;
  font-size: 12.5px; line-height: 1.4;
  border-bottom: 1px dotted #D4D1CA;
  transition: color 0.15s ease, border-color 0.15s ease, padding-left 0.15s ease;
}
.post-toc-list li:last-child a { border-bottom: none; }
.post-toc-list a:hover { color: #01696F; border-bottom-color: #01696F; padding-left: 4px; }
.toc-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; font-weight: 600; letter-spacing: 0.04em;
  color: #01696F; flex: 0 0 auto; min-width: 18px;
}
.toc-label { flex: 1 1 auto; }


/* Landing grid */
.insights-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; margin-top: 48px; }
@media (max-width: 860px) { .insights-grid { grid-template-columns: 1fr; gap: 24px; } }

.insight-card {
  display: flex; flex-direction: column;
  background: var(--surface, #F9F8F5);
  border: 1px solid var(--border, #D4D1CA);
  border-radius: 8px; overflow: hidden;
  text-decoration: none; color: inherit;
  transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
}
.insight-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(12,78,84,0.12); border-color: #01696F; }
.insight-card-hero { aspect-ratio: 16/9; overflow: hidden; background: #0C4E54; position: relative; }
.insight-card-hero img { display: block; width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
.insight-card:hover .insight-card-hero img { transform: scale(1.03); }
.insight-card-body { padding: 28px 28px 32px; }
.insight-card-meta {
  display: flex; align-items: center; gap: 10px;
  font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .04em;
  color: #7A7974; text-transform: uppercase; margin-bottom: 14px;
}
.insight-card-title {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(22px, 2.4vw, 28px);
  font-weight: 600; line-height: 1.15;
  color: #28251D; margin: 0 0 12px;
}
.insight-card-desc { font-size: 15px; line-height: 1.55; color: #4A4844; margin: 0 0 18px; }
.insight-card-cta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; letter-spacing: .04em; text-transform: uppercase;
  color: #01696F; font-weight: 600;
}
.post-pillar {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
  color: #01696F; font-weight: 600;
}
.post-dot { color: #BAB9B4; }
.post-time { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .04em; color: #7A7974; text-transform: uppercase; }

/* -------- Post page -------- */
.post-hero { width: 100%; aspect-ratio: 16/6; overflow: hidden; background: #0C4E54; }
@media (max-width: 700px) { .post-hero { aspect-ratio: 16/9; } }
.post-hero img { display: block; width: 100%; height: 100%; object-fit: cover; }

.post-head { padding-top: 64px; padding-bottom: 32px; max-width: 780px; }
.post-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
.post-back {
  font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .04em;
  color: #7A7974; text-decoration: none; text-transform: uppercase; font-weight: 500;
  margin-right: 8px;
}
.post-back:hover { color: #01696F; }
.post-date { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .04em; color: #7A7974; text-transform: uppercase; }

.post-title {
  font-family: 'Inter Tight', sans-serif;
  font-weight: 700;
  font-size: clamp(38px, 5.5vw, 64px);
  line-height: 1.02;
  letter-spacing: -0.02em;
  color: #28251D;
  margin: 0 0 32px;
  max-width: 22ch;
}
.post-lead { max-width: 68ch; }
.post-lead-para {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(19px, 1.6vw, 22px);
  line-height: 1.55; color: #28251D;
  margin: 0 0 20px; font-weight: 400;
}
.post-lead-para:last-child { margin-bottom: 0; }

.post-body { padding-top: 32px; padding-bottom: 64px; }
.post-section { margin-bottom: 64px; position: relative; }
.post-section:last-of-type { margin-bottom: 40px; }
.post-section-num {
  display: block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; font-weight: 600; letter-spacing: .06em;
  color: #01696F; margin-bottom: 12px;
}
.post-h2 {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(26px, 2.6vw, 32px);
  font-weight: 600; line-height: 1.15;
  color: #28251D; margin: 0 0 20px;
  max-width: 32ch; letter-spacing: -0.01em;
}
.post-h3 {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(19px, 1.8vw, 22px);
  font-weight: 600; line-height: 1.25;
  color: #28251D; margin: 24px 0 12px;
}
.post-section p, .post-body p {
  font-family: 'Inter Tight', sans-serif;
  font-size: 17px; line-height: 1.7;
  color: #28251D; margin: 0 0 20px; font-weight: 400;
  max-width: 65ch;
}

/* Drop cap on the first paragraph of each section */
.post-section > p:first-of-type::first-letter {
  font-family: 'Inter Tight', sans-serif;
  font-size: 4.2em; line-height: 0.9;
  font-weight: 600;
  color: #01696F;
  float: left;
  padding: 6px 12px 0 0;
  margin-top: 2px;
}
@media (max-width: 720px) {
  .post-section > p:first-of-type::first-letter { font-size: 3.6em; padding-right: 10px; }
}

/* Pull quote — floats right on desktop, centered on mobile */
.post-pullquote {
  font-family: 'Inter Tight', sans-serif;
  font-size: 22px; line-height: 1.35;
  font-weight: 500;
  color: #0C4E54;
  margin: 8px 0 24px;
  padding: 16px 0 16px 24px;
  border-left: 3px solid #01696F;
  max-width: 62ch;
}
.post-pullquote::before { content: "C"; color: #01696F; font-size: 1.6em; line-height: 0; vertical-align: -0.35em; margin-right: 4px; font-family: Georgia, serif; }
.post-pullquote::after  { content: "D"; color: #01696F; font-size: 1.6em; line-height: 0; vertical-align: -0.35em; margin-left: 2px; font-family: Georgia, serif; }

/* Stat callout — a highlighted number + short label */
.post-stat {
  display: block;
  margin: 32px 0;
  padding: 24px 28px;
  background: linear-gradient(135deg, #F0F8F9 0%, #E6F3F5 100%);
  border-left: 4px solid #01696F;
  border-radius: 2px;
}
.post-stat-number {
  display: block;
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(38px, 5vw, 54px);
  font-weight: 600; line-height: 1;
  color: #0C4E54;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
  font-variant-numeric: tabular-nums;
}
.post-stat-label {
  display: block;
  font-family: 'Inter Tight', sans-serif;
  font-size: 14px; line-height: 1.5;
  color: #4A4844;
  max-width: 52ch;
}

/* Section eyebrow rule — a thin teal bar above the section number */
.post-section::before {
  content: "";
  display: block;
  width: 32px;
  height: 2px;
  background: #01696F;
  margin-bottom: 16px;
}
.post-section:first-of-type::before { display: none; }
.post-section p:last-child { margin-bottom: 0; }
.post-section a, .post-body a { color: #01696F; text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
.post-section a:hover, .post-body a:hover { color: #0C4E54; text-decoration-thickness: 2px; }

.post-section ul, .post-section ol { margin: 0 0 18px 0; padding-left: 22px; }
.post-section li { font-size: 17px; line-height: 1.72; color: #28251D; margin-bottom: 8px; }

/* -------- Infographic figure -------- */
.post-figure {
  margin: 48px 0 56px;
  padding: 36px 36px 28px;
  background: linear-gradient(180deg, #FAFAF7 0%, #F5F3ED 100%);
  border: 1px solid #D4D1CA;
  border-top: 3px solid #01696F;
  border-radius: 3px;
  box-shadow: 0 1px 3px rgba(40, 37, 29, 0.04), 0 8px 24px rgba(40, 37, 29, 0.03);
}
@media (max-width: 720px) { .post-figure { padding: 24px 20px 20px; margin: 32px 0 40px; } }
.post-figure-eyebrow {
  display: inline-block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: .12em;
  color: #01696F; font-weight: 600; text-transform: uppercase;
  margin-bottom: 20px;
  padding-bottom: 8px;
  border-bottom: 1px solid #D4D1CA;
  min-width: 120px;
}
.post-figure-svg { width: 100%; margin-bottom: 20px; }
.post-figure-svg svg { display: block; width: 100%; height: auto; max-width: 100%; }
.post-figure figcaption {
  display: block;
  border-top: 1px solid #E8E6E0;
  padding-top: 16px;
}
.post-figure-caption {
  display: block;
  font-family: 'Inter Tight', sans-serif;
  font-size: 15px; line-height: 1.5; color: #28251D;
  font-weight: 500; margin-bottom: 6px;
}
.post-figure-source {
  display: block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: .04em;
  color: #7A7974; text-transform: uppercase;
}
@media (max-width: 700px) {
  .post-figure { padding: 20px 16px 16px; margin: 32px -16px 40px; border-radius: 0; }
}

/* -------- Kicker -------- */
.post-kicker {
  margin-top: 48px; padding: 40px 40px 44px;
  background: #F0EEE8;
  border-left: 3px solid #01696F;
  border-radius: 0 4px 4px 0;
}
.post-kicker p {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(19px, 1.7vw, 22px);
  line-height: 1.5; color: #28251D;
  margin: 0 0 24px; font-weight: 500;
}
@media (max-width: 700px) { .post-kicker { padding: 24px 20px 28px; } }

/* -------- Related -------- */
.related-section { padding-top: 80px; padding-bottom: 80px; background: #F7F6F2; }
.related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
@media (max-width: 860px) { .related-grid { grid-template-columns: 1fr; } }
.related-card {
  display: flex; flex-direction: column; padding: 28px;
  background: #FBFBF9;
  border: 1px solid #D4D1CA; border-radius: 6px;
  text-decoration: none; color: inherit;
  transition: transform .24s ease, border-color .24s ease, box-shadow .24s ease;
}
.related-card:hover { transform: translateY(-3px); border-color: #01696F; box-shadow: 0 10px 30px rgba(12,78,84,.08); }
.related-pillar {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: .06em; text-transform: uppercase;
  color: #01696F; font-weight: 600; margin-bottom: 12px;
}
.related-card h3 {
  font-family: 'Inter Tight', sans-serif;
  font-size: 20px; font-weight: 600; line-height: 1.22;
  color: #28251D; margin: 0 0 20px; flex: 1 1 auto;
}
.related-cta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; letter-spacing: .04em; text-transform: uppercase;
  color: #01696F; font-weight: 600;
}
